# optional local seed overrides
# SEED_USER_EMAIL=user@example.com
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_USER_PASSWORD=Password123!
# SEED_ADMIN_PASSWORD=Password123!
ACCESS_TOKEN_SECRET=dev-access-token-secret-change-me
TOKEN_HASH_SECRET=dev-token-hash-secret-change-me
ACCESS_ONLY_REFRESH_SECRET=dev-access-only-refresh-secret
TWO_FACTOR_SECRET_ENCRYPTION_KEY=dev-two-factor-secret-key
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Google OAuth (optional — set client id/secret to enable)
# Redirect URI must match admin proxy callback URL
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5102/api/auth/oauth/google/callback
