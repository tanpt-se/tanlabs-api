{
	"name": "tanlabs-api",
	"description": "TanLabs Auth API on Cloudflare Workers + Hono + Chanfana + D1.",
	"cloudflare": {
		"label": "Backend OpenAPI Template",
		"products": [
			"Workers",
			"D1"
		],
		"categories": [
			"storage"
		],
		"docs_url": "https://chanfana.com",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/1b2805d9-e7fb-4576-5176-6b409e251800/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/cbde46cf-20fa-4548-7f70-1ae8c2f48900/preview",
		"publish": true
	},
	"dependencies": {
		"@paralleldrive/cuid2": "2.2.2",
		"chanfana": "2.8.3",
		"hono": "4.11.1",
		"jose": "6.0.11",
		"otpauth": "9.4.0",
		"zod": "3.25.67"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260613.1",
		"@types/node": "24.10.1",
		"tsx": "4.19.4",
		"typescript": "5.9.3",
		"wrangler": "4.88.0"
	},
	"private": true,
	"scripts": {
		"cf-typegen": "wrangler types",
		"deploy": "wrangler deploy --env production",
		"dev": "pnpm seedLocalDb && pnpm seedAuth && wrangler dev",
		"predeploy": "wrangler d1 migrations apply DB --remote --env production",
		"schema": "npx chanfana",
		"seedLocalDb": "wrangler d1 migrations apply DB --local",
		"seedAuth": "tsx scripts/seed-auth.ts",
		"seedAuth:remote": "tsx scripts/seed-auth.ts --remote --env production"
	}
}
